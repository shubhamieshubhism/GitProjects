{
    "name": "ecommerce-cypress-tests",
    "version": "1.0.0",
    "scripts": {
        "cy:open": "cypress open",
        "cy:run": "cypress run",
        "cy:run:report": "cypress run --reporter mochawesome && npx mochawesome-merge cypress/results/*.json > cypress/results/cypress-report.json",
        "start:app": "npx http-server . -p 3000 --silent",
        "test": "start-server-and-test start:app http://localhost:3000 cy:run"
    },
    "devDependencies": {
        "cypress": "^13.6.0",
        "http-server": "^14.1.1",
        "mochawesome": "^7.1.4",
        "mochawesome-merge": "^5.1.1",
        "mochawesome-report-generator": "^6.3.2",
        "start-server-and-test": "^2.0.3"
    }
}
