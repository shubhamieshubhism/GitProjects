# =============================================================
# CREDENTIALS
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.
# =============================================================
SHUBHAM_EMAIL=your_email@example.com
SHUBHAM_PASS=your_password

# =============================================================
# ANDROID CONFIG
# =============================================================
PLATFORM_NAME=android
APPIUM_SERVER_URL=http://127.0.0.1:4723
UDID=emulator-5554
DEVICE_NAME=sdk_gphone64_x86_64
APP_PATH=src/test/resources/App/app-development-release.apk
ANDROID_PLATFORM_VERSION=34
ANDROID_APP_PACKAGE=com.swiftlyr.app.dev
ANDROID_APP_ACTIVITY=com.swiftlyr.app.MainActivity

# =============================================================
# IOS CONFIG
# =============================================================
UDID_IOS=YOUR-IOS-UDID-HERE
IOS_DEVICE_NAME=SwiftLyr Test iPhone
IOS_PLATFORM_VERSION=18.2
IOS_BUNDLE_ID=com.swiftlyr.app.dev
APP_PATH_IOS=src/test/resources/App/Runner.app

# =============================================================
# BEHAVIOR FLAGS
# =============================================================
HEADLESS=true
CI_MODE=false
LOCAL_TESTING=true

# =============================================================
# APPIUM SERVER
# Run: which node — to get the correct path on your machine
# =============================================================
APPIUM_NODE_PATH=/usr/local/bin/node
