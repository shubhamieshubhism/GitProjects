# OpenAI (optional – only needed if local Ollama fails)
OPENAI_API_KEY=sk-...

# Ollama
OLLAMA_MODEL=llama2:7b
OLLAMA_BASE_URL=http://localhost:11434

# Embedding model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
RETRIEVAL_K=3
DENSE_WEIGHT=0.5
BM25_WEIGHT=0.5

# LLM temperature
TEMPERATURE=0.0

# OpenAI fallback model
OPENAI_MODEL=gpt-3.5-turbo